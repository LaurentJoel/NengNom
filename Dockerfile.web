FROM node:22-alpine

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Copy everything from root
COPY . .

# Install dependencies using pnpm
RUN pnpm install --frozen-lockfile 2>&1 | tail -30

# Build the web frontend from root using pnpm filter
RUN pnpm --filter @neng-nom/web run build

EXPOSE 3000

# Run the frontend server directly with Node
CMD ["sh", "-c", "cd /app/packages/web && pnpm start"]
