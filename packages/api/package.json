{
  "name": "@neng-nom/api",
  "version": "1.0.0",
  "description": "Neng-Nom Backend API",
  "type": "module",
  "main": "dist/server.js",
  "exports": {
    ".": {
      "import": "./dist/server.js"
    },
    "./app": {
      "import": "./dist/app.js"
    }
  },
  "scripts": {
    "dev": "node --import tsx --watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/compress": "^6.4.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^6.7.0",
    "@fastify/multipart": "^8.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^1.10.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "@neng-nom/shared": "workspace:*",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.7.3",
    "fastify": "^4.25.2",
    "fastify-plugin": "^6.0.0",
    "groq-sdk": "^0.3.3",
    "ioredis": "^5.3.2",
    "opossum": "^8.1.0",
    "pino": "^8.17.2",
    "pino-http": "^10.2.0",
    "socket.io": "^4.7.2",
    "uuid": "^14.0.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@testcontainers/postgresql": "^10.8.2",
    "@testcontainers/redis": "^10.8.2",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "prisma": "^5.22.0",
    "supertest": "^6.3.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}
