# Node Environment
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://neng_nom:devpassword@localhost:5432/neng_nom_dev
DIRECT_DATABASE_URL=postgresql://neng_nom:devpassword@localhost:5432/neng_nom_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-long
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# AI/LLM
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# Media
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Communications
RESEND_API_KEY=re_your_key_here
AFRICAS_TALKING_API_KEY=your-at-key
AFRICAS_TALKING_USERNAME=your-at-username

# App
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
LOG_LEVEL=debug
