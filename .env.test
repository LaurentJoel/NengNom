# Test environment - Testcontainers will override DB/Redis URLs
NODE_ENV=test
PORT=3002
LOG_LEVEL=error

# JWT (test values)
JWT_ACCESS_SECRET=test-super-secret-access-key-min-32-chars-long
JWT_REFRESH_SECRET=test-super-secret-refresh-key-min-32-chars-long
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# AI/LLM (dummy)
GROQ_API_KEY=gsk_test_key_dummy_value
GROQ_MODEL=llama-3.1-70b-versatile

# Media (dummy)
CLOUDINARY_CLOUD_NAME=test-cloud
CLOUDINARY_API_KEY=test-key
CLOUDINARY_API_SECRET=test-secret

# Communications (dummy)
RESEND_API_KEY=re_test_key_dummy_value
AFRICAS_TALKING_API_KEY=test-at-key
AFRICAS_TALKING_USERNAME=test-at-username

# App
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
